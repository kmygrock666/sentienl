TS_DATA_DIR=data
TS_OUTPUT_DIR=outputs
# Local development (SQLite file in folder):
TS_DATABASE_URL=sqlite:///data/db/trading_system.db
# Production/PostgreSQL example:
# TS_DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/trading_system
# Optional override. Default already points to TWSE holidaySchedule official endpoint.
# TS_TWSE_HOLIDAY_URL_TEMPLATE=https://www.twse.com.tw/holidaySchedule/holidaySchedule?queryYear={roc_year}&response=html
# Optional stock master sources. If unset, `sync-stocks --source-mode auto` will fall back to fixture.
# TS_TWSE_STOCK_MASTER_URL=https://example.com/twse_stocks.csv
# TS_TPEX_STOCK_MASTER_URL=https://example.com/tpex_stocks.csv
TS_TIMEOUT_SECONDS=20
TS_MAX_RETRIES=3
TS_RETRY_BACKOFF_SECONDS=1
TS_RETRY_JITTER_SECONDS=0.25
TS_MIN_DELAY_SECONDS=0.2
TS_MAX_DELAY_SECONDS=0.8
TS_DATA_VERSION=v1
TS_LOG_LEVEL=INFO
# Telegram 通知（盤中排程使用）。未設定時通知功能自動停用。
# TS_TG_TOKEN=123456:your-bot-token
# TS_TG_CHAT_ID=-100123456789
# FinMind API token（券商分點主力買賣超需 Sponsor 等級，至 https://finmindtrade.com 註冊取得）
# TS_FINMIND_TOKEN=your-finmind-sponsor-token
